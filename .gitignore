# IPL binary distribution (separate repo / releases)
ipl_binary/

# PMDNEO Step 7 path B / c1 採用 (= ADR-0021 §決定 5 + docs/design/pne_binary_layout.md §6)
# converter 生成 + build-poc.sh による cp の generated artifact、 手編集禁止、
# source of truth は assets/pne/ 配下 (= .PNE + samples-map-adpcmb.yaml)
vendor/ngdevkit-examples/00-template/assets/samples-map-adpcma.yaml
vendor/ngdevkit-examples/00-template/assets/samples-map-adpcmb.yaml
# 注意 (= 強い glob、 future contributor 向け):
#   下記 *.adpcma glob は **scripts/pne-to-ngdevkit.py が生成する artifact のみ** を
#   想定。 この dir 配下に手書き .adpcma を置かない前提 (= source of truth は
#   `.PNE` 経由のみ、 path B / c1 規律)。 もし手書き .adpcma を持ちたい場合は
#   `assets/pne/` 配下や別 dir に置き、 converter / build-poc.sh で配置する流儀へ
#   移行する (= 本 ignore は変更しない、 path B 規律を曲げない)。
vendor/ngdevkit-examples/00-template/assets/*.adpcma
*.ipl

# claude / agent harness
.claude/USER_STATUS.md
.claude/worktrees/

# diary (個人記録、 git 管理外)
dev-diary/

# work memo (個人作業メモ、 git 管理外)
docs/work/

# internal documents for AI-assisted work logs / dense verification notes
internal-docs/*
!internal-docs/README.md

# MAME / gngeo 起動の副作用 (= cfg / nvram / snap directory)
cfg/
nvram/
snap/
vendor/ngdevkit-examples/*/cfg/
vendor/ngdevkit-examples/*/nvram/
vendor/ngdevkit-examples/*/snap/

# secrets
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# CLAUDE.md は内部開発用、 git 管理外
CLAUDE.md

# vendor/ngdevkit-examples/ の generated file (= ./configure 実行で生成)
vendor/ngdevkit-examples/config.mk
vendor/ngdevkit-examples/configure
vendor/ngdevkit-examples/config.log
vendor/ngdevkit-examples/config.status
vendor/ngdevkit-examples/autom4te.cache/
vendor/ngdevkit-examples/aclocal.m4

# 各 example の build artifact
vendor/ngdevkit-examples/*/build/
vendor/ngdevkit-examples/*/snap/
vendor/ngdevkit-examples/*/setup/.checkin
vendor/ngdevkit-examples/*/Makefile.config

# 06-sound-adpcma 等の configure で 00-template から rsync される generated file
vendor/ngdevkit-examples/*/build.mk
vendor/ngdevkit-examples/*/emu.mk
vendor/ngdevkit-examples/*/config.mk
# ただし 00-template/ の build.mk + emu.mk は git tracked (= 上流原本)
!vendor/ngdevkit-examples/00-template/build.mk
!vendor/ngdevkit-examples/00-template/emu.mk

# 00-template/ に scripts/build-poc.sh で生成される symlink (src/driver/ への参照)
vendor/ngdevkit-examples/00-template/PMDNEO.s
vendor/ngdevkit-examples/00-template/standalone_test.s
vendor/ngdevkit-examples/00-template/*.inc
vendor/ngdevkit-examples/00-template/sample_m.s
vendor/ngdevkit-examples/00-template/song_data.inc
vendor/ngdevkit-examples/00-template/songs/

# 改造 MAME (= vendor/mame-fork、 ymfm + z80 trace harness、 約 1.5 GB)
# git track せず neo-sisters/vendor/mame-fork から copy で setup する流儀。
# 改造内容: 3rdparty/ymfm/src/ymfm_opn.cpp + src/devices/cpu/z80/z80.cpp
# (= YMFM_TRACE / Z80_MEM_TRACE 環境変数で TSV 出力)、 setup 手順は後続 sprint で
# docs/setup/mame-fork-setup.md として起票予定
vendor/mame-fork/

# PMDDotNET (= ADR-0013/0014/0015/0016 改造 PMDDotNET 路線で改修対象、 source は git tracked、 build artifact + backup + reference wav + Windows player binary は除外)
vendor/PMDDotNET/**/bin/
vendor/PMDDotNET/**/obj/
vendor/PMDDotNET/**/.vs/
vendor/PMDDotNET/PMDDotNETConsole.Net4_bk/
vendor/PMDDotNET/PMDDotNETPlayer_bk/
vendor/PMDDotNET/**/*.wav
vendor/PMDDotNET/**/*.bak
vendor/PMDDotNET/PMDDotNETPlayer/lib/
vendor/pmdmini-patched/

# 音色検証 local DB (= ADR-0005)
/data/
