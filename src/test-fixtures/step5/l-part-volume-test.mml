#Title		ADR-0016 step 5 delta-a L V cmd test (= adpcma_volume_hook bug fix verify)
#Composer	M.Koshikawa.
#Memo		L body 内 v255 で adpcma_volume_hook 経由 reg 0x08+ch 書込確認、 bug fix gate
#PNEFile	"step5.PNE"

; FM voice (= reference template、 voice-ar-04.mml と同じ)
; nm alg fbl
@001 000 005
; ar  dr  sr  rr  sl  tl  ks  ml  dt ams
 031 000 000 000 000 017 000 001 003 000
 031 000 000 000 000 025 000 002 003 000
 031 000 000 000 000 038 000 001 003 000
 004 018 000 015 002 000 000 001 003 000

; L part = ADPCM-A ch 0、 v15 (= 小文字 v、 0-15 範囲 max) + @0 sample
; PMD V4.8s 規約: v cmd = 0-15 (= 16 段階、 4 bit)
; L body emit 期待: 0xFD 0x0F (= v cmd byte + value 15) + @ cmd 2 byte + note/len/term
; 駆動 chain: v15 → driver comv → V(1) table 引き → PART_OFF_VOLUME = 240
;          → adpcma_volume_hook で /8 = 30 → reg 0x08+0 = pan_bits[0] | 0x1E = 0xDE
L	v15 @0 o4 l1 c
