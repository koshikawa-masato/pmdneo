    ],
    "rows": [
      { "opcode": "@",  "name": "音色設定",            "category": "voice",  "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comat (standalone_test.s L4358) が実装。FM (CHIP_TYPE=0) は voice_table から pm dneo_fm_voice_set 呼び出し。ADPCM-A (L-Q part, CHIP_TYPE=2) は PART_OFF_INSTRUMENT に index 保存。SSG は既存通り無視。ADR-0016 β-2a 拡張。" },
      { "opcode": "o",  "name": "octave",              "category": "pitch",  "manual": "tbd", "compiler": "tbd", "driver": "not_implemented", "driver_detail": "MMLからの明示的な o / < / > コマンドハンドラ未確認。内部では PART_OFF_OCTAVE / SHIFT で状態管理はあるが、MML opcode としての絶対/相対 octave 指定は v2 driver で未サポート。" },
      { "opcode": "<",  "name": "octave down",         "category": "pitch",  "manual": "tbd", "compiler": "tbd", "driver": "not_implemented", "driver_detail": "MMLからの明示的な o / < / > コマンドハンドラ未確認。内部では PART_OFF_OCTAVE / SHIFT で状態管理はあるが、MML opcode としての絶対/相対 octave 指定は v2 driver で未サポート。" },
      { "opcode": ">",  "name": "octave up",           "category": "pitch",  "manual": "tbd", "compiler": "tbd", "driver": "not_implemented", "driver_detail": "MMLからの明示的な o / < / > コマンドハンドラ未確認。内部では PART_OFF_OCTAVE / SHIFT で状態管理はあるが、MML opcode としての絶対/相対 octave 指定は v2 driver で未サポート。" },
      { "opcode": "l",  "name": "default length",      "category": "rhythm", "manual": "tbd", "compiler": "tbd", "driver": "not_implemented", "driver_detail": "MML の l (default length) コマンドを直接解釈するハンドラは v2 driver で未確認。note 発音時の length は主にコンパイラ側で埋め込まれる前提。" },
      { "opcode": "v",  "name": "volume (SSG range)",  "category": "volume", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comv (PMD_Z80.inc L1811) で PART_OFF_VOLUME に値を保存。v2 側でも volume 反映は進んでいるが、MML v/V コマンドからの完全な per-part 制御はまだ partial。" },
      { "opcode": "V",  "name": "volume (FM range)",   "category": "volume", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comv (PMD_Z80.inc L1811) で PART_OFF_VOLUME に値を保存。v2 側でも volume 反映は進んでいるが、MML v/V コマンドからの完全な per-part 制御はまだ partial。" },
      { "opcode": "t",  "name": "tempo",               "category": "rhythm", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comt (PMD_Z80.inc L1816) で driver_tempo_d / driver_tempo_48 を更新。v2 でもテンポは機能しているが、sub-tick モデルへの完全移行は進行中。" },
      { "opcode": "q",  "name": "quantize (gate)",     "category": "rhythm", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comq / comq2 / comq3 / comq4 が複数存在し、PART_OFF_QDATA 系に保存。gate 制御はかなり進んでいる。" },
      { "opcode": "Q",  "name": "quantize ratio",      "category": "rhythm", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comq / comq2 / comq3 / comq4 が複数存在し、PART_OFF_QDATA 系に保存。gate 制御はかなり進んでいる。" },
      { "opcode": "p",  "name": "pan",                 "category": "spatial","manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "ADPCM-A/B で adpcma_panset / adpcmb_panset が実装済み。FM pan は v2 voice/keyon 経路で進展中。MML p/P コマンドの全 chip 対応はまだ partial。" },
      { "opcode": "P",  "name": "pan (alt)",           "category": "spatial","manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "ADPCM-A/B で adpcma_panset / adpcmb_panset が実装済み。FM pan は v2 voice/keyon 経路で進展中。MML p/P コマンドの全 chip 対応はまだ partial。" },
      { "opcode": "[",  "name": "loop start",          "category": "flow",   "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comstloop / comedloop / comexloop が古典テーブルに存在。v2 側でも loop 処理は基本機能として動いているが、複雑なネストや | break の完全性は検証中。" },
      { "opcode": "]",  "name": "loop end",            "category": "flow",   "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comstloop / comedloop / comexloop が古典テーブルに存在。v2 側でも loop 処理は基本機能として動いているが、複雑なネストや | break の完全性は検証中。" },
      { "opcode": "|",  "name": "loop break (last)",   "category": "flow",   "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comstloop / comedloop / comexloop が古典テーブルに存在。v2 側でも loop 処理は基本機能として動いているが、複雑なネストや | break の完全性は検証中。" },
      { "opcode": "&",  "name": "tie",                 "category": "rhythm", "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "comtie が存在し TIEFLAG を立てる。v2 でも legato / tie 挙動は一部実装済み。" },
      { "opcode": "K",  "name": "key shift",           "category": "pitch",  "manual": "tbd", "compiler": "tbd", "driver": "not_implemented", "driver_detail": "MML K コマンド（key shift）の専用ハンドラは現在の v2 driver で明確に確認できず。" },
      { "opcode": "s",  "name": "SSG envelope shape",  "category": "ssg",    "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "psgenvset / envelope_extend 系が存在。SSG envelope は古典テーブルでサポートされているが、v2 での優先度は低め。" },
      { "opcode": "M",  "name": "SSG mixer",           "category": "ssg",    "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "lfoset (0xF2 M) としてテーブルにあり、mixer 制御は基本的に動く。" },
      { "opcode": "n",  "name": "noise freq (SSG)",    "category": "ssg",    "manual": "tbd", "compiler": "tbd", "driver": "partial", "driver_detail": "psgnoise / psgnoise_move が存在。noise 制御は古典的にはサポートされている。" }
    ]
